{
  "name": "saas-dashboard-api-node",
  "version": "1.0.0",
  "description": "CRUD de usuarios en Node.js + TypeScript con arquitectura limpia",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "mysql2",
    "crud",
    "mvc"
  ],
  "author": "Adolfo Garcia",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.3",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
